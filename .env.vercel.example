// ==========================================
// Vercel Environment Variables Configuration
// ==========================================
// Add this in: Vercel Dashboard → Settings → Environment Variables
// ==========================================

/*
  Variable Name: NEXT_PUBLIC_API_URL
  Value: https://your-backend-url.railway.app/api
  
  Environments: 
  ✅ Production
  ✅ Preview  
  ✅ Development

  Description:
  Backend API base URL. Change this based on your deployment:
  - Local Dev: http://localhost:3001/api
  - Production: https://your-backend.railway.app/api
  
  IMPORTANT:
  - Must include /api at the end
  - Must start with https:// in production
  - No trailing slash
*/

// Example Values for Different Environments:

// Production (Railway)
NEXT_PUBLIC_API_URL=https://sahyogfarm-production.up.railway.app/api

// Development (Local)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

// Preview (Staging - if you have separate backend)
NEXT_PUBLIC_API_URL=https://sahyogfarm-staging.up.railway.app/api
