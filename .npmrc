# ==========================================
# NPM Configuration
# ==========================================

# Use exact versions in package.json
save-exact=false

# Always save installed packages to package.json
save=true

# Security - audit level
audit-level=moderate

# Logging
loglevel=warn

# Engine strict - enforce Node version from package.json
engine-strict=false

# Progress bar
progress=true

# Legacy peer deps (if needed for Next.js)
legacy-peer-deps=false
