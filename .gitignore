# ==========================================
# Next.js Frontend - .gitignore
# ==========================================

# ==================
# Dependencies
# ==================
/node_modules
/.pnp
.pnp.*
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Lock files (keep package-lock.json for consistent installs)
# Uncomment to ignore: package-lock.json
yarn.lock
pnpm-lock.yaml

# ==================
# Next.js Build Output
# ==================
/.next/
/out/
.next/
out/

# ==================
# Production Build
# ==================
/build
/dist

# ==================
# Environment Variables (SENSITIVE!)
# ==================
.env
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# Keep example files
!.env.example
!.env.vercel.example

# ==================
# Testing & Coverage
# ==================
/coverage
.nyc_output
*.lcov

# ==================
# Logs
# ==================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# ==================
# OS & System Files
# ==================
.DS_Store
.DS_Store?
*.pem
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ==================
# IDE & Editor Files
# ==================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
.code-workspace
*.sublime-project
*.sublime-workspace

# ==================
# Vercel Deployment
# ==================
.vercel

# ==================
# TypeScript
# ==================
*.tsbuildinfo
next-env.d.ts

# ==================
# PWA (if using)
# ==================
**/public/workbox-*
**/public/worker-*.js
**/public/sw.js
**/public/fallback-*.js

# ==================
# Storybook (if using)
# ==================
storybook-static/
.storybook-out/

# ==================
# Turbo (if using)
# ==================
.turbo

# ==================
# Misc
# ==================
.cache/
.parcel-cache/
.serverless/
